# ── Adobe Campaign Classic ───────────────────────────────────────────────────
# SOAP router URL – change host/port to match your ACC instance
ACC_ENDPOINT=http://127.0.0.1:8080/nl/jsp/soaprouter.jsp

# Timeout in seconds for every SOAP call
SOAP_TIMEOUT=30.0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS_RAW=http://localhost:3000,http://localhost:5173

# ── Security ─────────────────────────────────────────────────────────────────
# Random secret – used for future signed cookies / JWT; MUST be changed
SECRET_KEY=replace-with-a-long-random-secret

# ── General ──────────────────────────────────────────────────────────────────
# Set to true for verbose DEBUG logging (never use in production)
DEBUG=false
