# Copy to .env and fill in real values. .env is git-ignored.
AJO_CLIENT_ID=your-client-id
AJO_CLIENT_SECRET=your-client-secret
AJO_ORG_ID=XXXXXXXXXXXXXXXX@AdobeOrg
AJO_SANDBOX=prod
AJO_SCOPES=openid,AdobeID,read_organizations,additional_info.projectedProductContext,session

# Optional regional overrides (defaults shown)
AJO_IMS_TOKEN_URL=https://ims-na1.adobelogin.com/ims/token/v3
AJO_AEP_BASE_URL=https://platform.adobe.io

# Reference access token used to validate the user (identity claims are compared).
AJO_REFERENCE_ACCESS_TOKEN=your-reference-access-token
