# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://<user>:<password>@localhost:5432/acc_ajo

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate your own: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-generated-fernet-key-here

# ── Adobe Campaign Classic ────────────────────────────────────────────────────
ACC_ENDPOINT=https://<your-acc-instance>/nl/jsp/soaprouter.jsp
SOAP_TIMEOUT=30.0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS_RAW=http://localhost:3000,http://localhost:5173

# ── Schema File Storage ───────────────────────────────────────────────────────
SCHEMA_STORAGE_DIR=/path/to/your/schema_files

# ── General ───────────────────────────────────────────────────────────────────
DEBUG=false
